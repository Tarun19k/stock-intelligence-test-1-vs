# Copy this file to .env and fill in your real keys.
# NEVER commit .env to version control.

# Anthropic — console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza...

# Perplexity — perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# Hugging Face — huggingface.co/settings/tokens
# Create a token with "Read" + "Inference" permissions.
# Used for direct HF model access (optional — Groq covers free open-source tiers).
HF_TOKEN=hf_...

# Groq — console.groq.com → API Keys → Create (free, no billing required)
# Powers the zero-cost open-source fallback tiers: hf-reasoning, hf-code, hf-fast.
# Free limits: Llama-3.3-70B 1k req/day · Llama-3.2-3B 14.4k req/day
GROQ_API_KEY=gsk_...

# LiteLLM proxy access key — any string you choose; used as ANTHROPIC_AUTH_TOKEN in Claude Code
# Generate one: python3 -c "import secrets; print('sk-local-' + secrets.token_hex(16))"
LITELLM_MASTER_KEY=my-local-proxy-key
